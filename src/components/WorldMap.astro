---
import { buildWorldMap, visitedCountries, MAP_WIDTH, MAP_HEIGHT } from '../lib/worldmap.mjs';

const { shapes, markers } = buildWorldMap();
const countries = visitedCountries();
const pad = (n) => String(n).padStart(2, '0');
---

<section class="map-section container">
  <div class="map-head">
    <h2>COUNTRIES VISITED</h2>
    <span class="rule"></span>
    <span class="meta">{countries.length} COUNTRIES</span>
  </div>

  <svg
    viewBox={`0 0 ${MAP_WIDTH} ${MAP_HEIGHT}`}
    role="img"
    aria-label={`World map with ${countries.length} visited countries highlighted`}
  >
    {
      shapes.map((s) => (
        <path d={s.d} class:list={['country', { visited: s.visited }]}>
          <title>{s.title}</title>
        </path>
      ))
    }
    {
      markers.map((m) => (
        <circle cx={m.x} cy={m.y} r="3.5" class="marker">
          <title>{m.title}</title>
        </circle>
      ))
    }
  </svg>

  <ol class="country-list">
    {
      countries.map((c, i) => (
        <li>
          <span class="num">{pad(i + 1)}</span>
          <span class="name">{c.name}</span>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .map-section {
    padding-top: 56px;
  }
  .map-head {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 22px;
  }
  .map-head h2 {
    font: 700 12px var(--sans);
    letter-spacing: 0.26em;
    margin: 0;
  }
  .map-head .rule {
    flex: 1;
    height: 1px;
    background: var(--line);
    align-self: center;
  }
  .map-head .meta {
    font: 400 9px var(--sans);
    letter-spacing: 0.18em;
    color: var(--sub);
  }
  svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .country {
    fill: var(--line);
    stroke: var(--bg);
    stroke-width: 0.5;
  }
  .country.visited {
    fill: var(--ink);
  }
  .country.visited:hover {
    fill: var(--sub);
  }
  .marker {
    fill: var(--ink);
    stroke: var(--bg);
    stroke-width: 1;
  }
  .country-list {
    list-style: none;
    margin: 34px 0 0;
    padding: 0;
    columns: 280px;
    column-gap: 40px;
  }
  .country-list li {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 8px 2px;
    border-bottom: 1px solid var(--line);
    break-inside: avoid;
  }
  .num {
    font: 400 9px var(--sans);
    letter-spacing: 0.14em;
    color: var(--sub);
  }
  .name {
    font: 700 15px var(--serif);
  }
</style>
