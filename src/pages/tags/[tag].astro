---
import Base from '../../layouts/Base.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Footer from '../../components/Footer.astro';
import { allPhotos, slugify } from '../../lib/data.mjs';
import { srcset, ogImageUrl, GRID_SIZES } from '../../lib/cdn.mjs';
import { SITE_NAME } from '../../lib/site.mjs';
import { graph, personNode, personRef, breadcrumbs } from '../../lib/schema.mjs';

// One static page per keyword: every photo carrying that tag, across all
// albums and ratings, newest first.
export function getStaticPaths() {
  const bySlug = new Map();
  for (const p of allPhotos()) {
    for (const tag of p.keywords) {
      const slug = slugify(tag);
      if (!bySlug.has(slug)) bySlug.set(slug, { tag, photos: [] });
      bySlug.get(slug).photos.push(p);
    }
  }
  return [...bySlug.entries()].map(([slug, { tag, photos }]) => ({
    params: { tag: slug },
    props: {
      tag,
      photos: photos.sort((a, b) => (b.dateTaken || '').localeCompare(a.dateTaken || '')),
    },
  }));
}

const { tag, photos } = Astro.props;
const albumCount = new Set(photos.map((p) => p.album)).size;
const lcp = photos[0];

const ld = Astro.site
  ? graph(
      {
        '@type': 'CollectionPage',
        name: `${tag} — ${SITE_NAME}`,
        description: `${photos.length} photographs tagged "${tag}" by Arnav Jindal.`,
        url: new URL(`/tags/${slugify(tag)}/`, Astro.site).href,
        author: personRef(Astro.site),
        mainEntity: {
          '@type': 'ItemList',
          numberOfItems: photos.length,
          itemListElement: photos.map((p, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: p.title,
            url: new URL(`/photo/${p.id}/`, Astro.site).href,
          })),
        },
      },
      personNode(Astro.site),
      breadcrumbs(Astro.site, [
        ['Home', '/'],
        [tag, `/tags/${slugify(tag)}/`],
      ])
    )
  : null;
---

<Base
  title={`${tag.toUpperCase()} — ${SITE_NAME}`}
  description={`${photos.length} photographs tagged "${tag}".`}
  active=""
  captionLeft={`${tag.toUpperCase()} — TAG`}
  captionRight={`${photos.length} PHOTOS · ${albumCount} ${albumCount === 1 ? 'ALBUM' : 'ALBUMS'}`}
  preload={lcp ? { srcset: srcset(lcp.key), sizes: GRID_SIZES } : null}
  ogImage={lcp
    ? {
        url: ogImageUrl(lcp.key),
        width: 1200,
        height: Math.round((1200 * lcp.height) / lcp.width),
        alt: `${lcp.title} — ${lcp.album}`,
      }
    : null}
>
  {ld && <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(ld)} />}
  <PhotoGrid {photos} />
  <Footer />
</Base>
