---
import Base from '../../layouts/Base.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Footer from '../../components/Footer.astro';
import { albums } from '../../lib/data.mjs';
import { srcset, ogImageUrl, imageUrl, GRID_SIZES } from '../../lib/cdn.mjs';
import { SITE_NAME } from '../../lib/site.mjs';
import { graph, personNode, personRef, breadcrumbs } from '../../lib/schema.mjs';

export function getStaticPaths() {
  return albums().map((a) => ({ params: { album: a.slug }, props: { album: a } }));
}

const { album } = Astro.props;
const lcp = album.photos[0];

const ld = graph(
  {
    '@type': 'ImageGallery',
    name: `${album.name} — ${SITE_NAME}`,
    description: `${album.count} photographs from ${album.name} by Arnav Jindal.`,
    url: Astro.site ? new URL(`/albums/${album.slug}/`, Astro.site).href : undefined,
    image: album.photos.slice(0, 6).map((p) => imageUrl(p.key, 1200)),
    author: Astro.site ? personRef(Astro.site) : { '@type': 'Person', name: 'Arnav Jindal' },
    // Enumerable list of the album's photo pages for crawlers/answer engines
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: album.count,
      itemListElement: album.photos.map((p, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: p.title,
        url: Astro.site ? new URL(`/photo/${p.id}/`, Astro.site).href : `/photo/${p.id}/`,
      })),
    },
  },
  Astro.site && personNode(Astro.site),
  Astro.site &&
    breadcrumbs(Astro.site, [
      ['Home', '/'],
      ['Albums', '/albums/'],
      [album.name, `/albums/${album.slug}/`],
    ])
);
---

<Base
  title={`${album.name} — ${SITE_NAME}`}
  description={`${album.count} photographs from ${album.name} by Arnav Jindal${album.year ? `, ${album.year}` : ''}.`}
  active="albums"
  captionLeft={`${album.name.toUpperCase()} — ALBUM`}
  captionRight={`${album.count} PHOTOS · NEWEST FIRST`}
  preload={lcp ? { srcset: srcset(lcp.key), sizes: GRID_SIZES } : null}
  ogImage={{
    url: ogImageUrl(album.cover.key),
    width: 1200,
    height: Math.round((1200 * album.cover.height) / album.cover.width),
    alt: `${album.name} album cover`,
  }}
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify(ld)} />
  <PhotoGrid photos={album.photos} />
  <Footer />
</Base>
