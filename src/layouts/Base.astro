---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { SITE_NAME, INSTAGRAM_URL, TWITTER_HANDLE } from '../lib/site.mjs';

const {
  title,
  description,
  active = 'home',
  captionLeft = '',
  captionRight = '',
  preload = null, // { srcset, sizes } for the likely LCP image
  ogImage = null, // { url, width, height, alt } for link unfurls
  ogType = 'website',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
const twitter = TWITTER_HANDLE && (TWITTER_HANDLE.startsWith('@') ? TWITTER_HANDLE : `@${TWITTER_HANDLE}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Arnav Jindal" />
    <meta name="theme-color" content="#0a0a0a" />
    <!-- Let Google show full-size image previews in Search/Discover -->
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="me" href={INSTAGRAM_URL} />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Link unfurls: OpenGraph (iMessage/WhatsApp/Slack/Discord/FB) + Twitter -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    {canonical && <meta property="og:url" content={canonical} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage.url} />
          <meta property="og:image:type" content="image/jpeg" />
          {ogImage.width && <meta property="og:image:width" content={String(ogImage.width)} />}
          {ogImage.height && <meta property="og:image:height" content={String(ogImage.height)} />}
          {ogImage.alt && <meta property="og:image:alt" content={ogImage.alt} />}
        </>
      )
    }
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage.url} />}
    {ogImage?.alt && <meta name="twitter:image:alt" content={ogImage.alt} />}
    {twitter && <meta name="twitter:site" content={twitter} />}
    {twitter && <meta name="twitter:creator" content={twitter} />}

    <link rel="preconnect" href="https://photocdn.dag.gy" />
    <link
      rel="preload"
      href="/fonts/source-serif-4-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      preload && (
        <link
          rel="preload"
          as="image"
          imagesrcset={preload.srcset}
          imagesizes={preload.sizes}
          fetchpriority="high"
        />
      )
    }
    <slot name="head" />
    <script is:inline>
      // Pre-paint theme: a stored toggle choice wins, otherwise the site
      // default is dark. Keep inline and first so there is no flash.
      (function () {
        try {
          document.documentElement.dataset.theme =
            localStorage.getItem('pf-theme') || 'dark';
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav {active} {captionLeft} {captionRight} />
    <slot />
  </body>
</html>
