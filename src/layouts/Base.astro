---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

const {
  title,
  description,
  active = 'home',
  captionLeft = '',
  captionRight = '',
  preload = null, // { srcset, sizes } for the likely LCP image
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/source-serif-4-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      preload && (
        <link
          rel="preload"
          as="image"
          imagesrcset={preload.srcset}
          imagesizes={preload.sizes}
          fetchpriority="high"
        />
      )
    }
    <script is:inline>
      // Pre-paint theme: a stored toggle choice wins, otherwise the site
      // default is dark. Keep inline and first so there is no flash.
      (function () {
        try {
          document.documentElement.dataset.theme =
            localStorage.getItem('pf-theme') || 'dark';
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav {active} {captionLeft} {captionRight} />
    <slot />
  </body>
</html>
